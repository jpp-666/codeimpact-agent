diff --git a/tests/test_fault_conditioning.py b/tests/test_fault_conditioning.py
new file mode 100644
index 0000000..c400b62
--- /dev/null
+++ b/tests/test_fault_conditioning.py
@@ -0,0 +1,93 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+import numpy as np
+import pytest
+
+torch = pytest.importorskip("torch")
+
+from scripts.train_router_v2 import (
+    FAULT_TYPES,
+    FAULT_FEATURE_NAMES,
+    extract_xy,
+    fault_type_one_hot,
+    feature_names_with_conditioning,
+)
+from src.models.router import FEATURE_NAMES, EXPERTS
+from src.models.router_mlp import WindowConditionalMLP
+from src.models.router_moe import MoESoftWeightRouter
+
+
+ROOT = Path(__file__).resolve().parents[1]
+LABELS = ROOT / "results" / "router_training" / "oracle_labels_multiwindow.jsonl"
+
+
+def _sample_rows(n: int = 20):
+    rows = []
+    with LABELS.open("r", encoding="utf-8") as f:
+        for line in f:
+            if line.strip():
+                rows.append(json.loads(line))
+            if len(rows) >= n:
+                break
+    return rows
+
+
+def test_fault_type_one_hot_order_is_fixed_and_correct():
+    vec = fault_type_one_hot("disk")
+    assert tuple(vec.keys()) == FAULT_FEATURE_NAMES
+    assert sum(vec.values()) == 1.0
+    assert vec["fault_disk"] == 1.0
+    for name in FAULT_FEATURE_NAMES:
+        if name != "fault_disk":
+            assert vec[name] == 0.0
+
+
+def test_unknown_fault_type_raises_value_error():
+    with pytest.raises(ValueError, match="Unknown fault_type"):
+        fault_type_one_hot("network")
+
+
+def test_conditioning_off_keeps_feature_dim_18():
+    rows = _sample_rows(5)
+    X, y, feat_names = extract_xy(rows, condition_on_fault_type=False)
+    assert X.shape[1] == len(FEATURE_NAMES) == 18
+    assert tuple(feat_names) == tuple(FEATURE_NAMES)
+
+
+def test_conditioning_on_gives_feature_dim_23():
+    rows = _sample_rows(5)
+    X, y, feat_names = extract_xy(rows, condition_on_fault_type=True)
+    assert X.shape[1] == 23
+    assert len(feat_names) == 23
+    assert tuple(feat_names[:18]) == tuple(FEATURE_NAMES)
+    assert tuple(feat_names[18:]) == FAULT_FEATURE_NAMES
+
+
+def test_conditioning_on_one_hot_tail_matches_fault_type():
+    rows = _sample_rows(10)
+    X, _, feat_names = extract_xy(rows, condition_on_fault_type=True)
+    tail = feat_names[18:]
+    tail_idx = {name: i for i, name in enumerate(tail)}
+    for row, vec in zip(rows, X):
+        fault = row["fault_type"]
+        one_hot = vec[18:]
+        assert np.isclose(one_hot.sum(), 1.0)
+        assert np.isclose(one_hot[tail_idx[f"fault_{fault}"]], 1.0)
+
+
+def test_mlp_accepts_23_dim_with_conditioning():
+    model = WindowConditionalMLP(n_features=23, n_experts=len(EXPERTS), hidden=32)
+    x = torch.randn(4, 23)
+    out = model(x)
+    assert out.shape == (4, len(EXPERTS))
+
+
+def test_moe_accepts_23_dim_with_conditioning():
+    model = MoESoftWeightRouter(n_features=23, n_experts=len(EXPERTS), hidden=32)
+    x = torch.randn(4, 23)
+    out = model(x)
+    assert out.shape == (4, len(EXPERTS))
+    assert torch.allclose(out.sum(dim=1), torch.ones(4), atol=1e-4)
