@@ -38,0 +39,27 @@ from src.models.router import (
+FAULT_TYPES = ("cpu", "delay", "disk", "loss", "mem")
+FAULT_FEATURE_NAMES = tuple(f"fault_{ft}" for ft in FAULT_TYPES)
+
+
+def fault_type_one_hot(fault_type: str) -> dict[str, float]:
+    fault_type = str(fault_type)
+    if fault_type not in FAULT_TYPES:
+        raise ValueError(
+            f"Unknown fault_type '{fault_type}'. Expected one of {FAULT_TYPES}"
+        )
+    return {name: (1.0 if name == f"fault_{fault_type}" else 0.0)
+            for name in FAULT_FEATURE_NAMES}
+
+
+def feature_names_with_conditioning(condition_on_fault_type: bool) -> tuple[str, ...]:
+    if not condition_on_fault_type:
+        return tuple(FEATURE_NAMES)
+    return tuple(FEATURE_NAMES) + FAULT_FEATURE_NAMES
+
+
+def row_to_features(row: dict, condition_on_fault_type: bool = False) -> dict[str, float]:
+    feats = {name: float(row[name]) for name in FEATURE_NAMES}
+    if condition_on_fault_type:
+        feats.update(fault_type_one_hot(row.get("fault_type")))
+    return feats
+
+
